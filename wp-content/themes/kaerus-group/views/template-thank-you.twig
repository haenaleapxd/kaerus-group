{% extends "base.twig" %}

{% block content %}
	<article class="thank-you-page is-style-dark">
		<div class="container xd-pb--lg">
			<div class="row">
				<div class="col-10 col-md-8 col-xl-6 offset-1 offset-md-2 offset-xl-3">

					<header class="page-header">
						<div class="page-icon">
							<img src="{{theme.link}}/build/images/svg/check-light.svg" alt="thankyou-check">
						</div>
						<h1 class="page-title">{{_e( 'Thanks for getting in touch!', 'xd' )}}</h1>
					</header>

					<div class="page-content">
						<p class="body-1">We’ve received your message and our team will get back to you as soon as we can.</p>
					</div>

				</div>
			</div>
		</div>
	</article>
{% endblock %}
