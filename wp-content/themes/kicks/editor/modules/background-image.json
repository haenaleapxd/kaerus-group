{
  "$schema": "../schema/module-schema.json",
  "title": "Background Image",
  "name": "background-image",
  "supports": [
    {
      "name": "xd/image-background",
      "attributes": {
        "backgroundImageDesktop": {
          "type": "object",
          "default": {},
          "cssVariable": true,
          "cssTransform": {
            "url": {
              "^(.+)$": "url($1)"
            }
          },
          "className": {
            "url": "xd-has-background-image"
          }
        },
        "backgroundImageMobile": {
          "type": "object",
          "default": {},
          "cssVariable": true,
          "cssTransform": {
            "url": {
              "^(.+)$": "url($1)"
            }
          },
          "className": {
            "url": "xd-has-background-image"
          }
        },
        "positionFixed": {
          "type": "boolean",
          "default": false,
          "className": "xd-has-background-image--fixed"
        }
      },
      "inspectorControls": [
        {
          "type": "XDImageControl",
          "attribute": "backgroundImageDesktop",
          "label": "Primary image"
        },
        {
          "type": "XDImageControl",
          "attribute": "backgroundImageMobile",
          "label": "Mobile Crop",
          "help": "Mobile crop image is optional"
        },
        {
          "activeState": "checked",
          "attribute": "positionFixed",
          "type": "ToggleControl",
          "label": "Background Position Fixed"
        }
      ]
    },
    {
      "name": "xd/background-overlay",
      "attributes": {
        "backgroundOverlay": {
          "type": "boolean",
          "default": true,
          "className": "xd-has-background-image--overlay"
        },
        "backgroundOpacity": {
          "type": "number",
          "default": 0.3,
          "cssVariable": true
        },
        "backgroundBlendMode": {
          "type": "string",
          "default": "normal",
          "cssVariable": true
        }
      }
    },
    {
      "name": "xd/background-overlay-controls",
      "inspectorControls": [
        {
          "activeState": "checked",
          "attribute": "backgroundOverlay",
          "type": "ToggleControl",
          "label": "Background Overlay"
        }
      ]
    },
    {
      "name": "xd/background-opacity-controls",
      "inspectorControls": [
        {
          "attribute": "backgroundOpacity",
          "type": "RangeControl",
          "label": "Background Opacity",
          "step": 0.05,
          "min": 0,
          "max": 1  
        }
      ]
    },
    {
      "name": "xd/background-blend-mode-controls",
      "inspectorControls": [
        {
          "attribute": "backgroundBlendMode",
          "type": "SelectControl",
          "label": "Background Blend Mode",
          "options": [
            { "label": "Normal", "value": "normal" },
            { "label": "Multiply", "value": "multiply" },
            { "label": "Overlay", "value": "overlay" },
            { "label": "Screen", "value": "screen" },
            { "label": "Darken", "value": "darken" },
            { "label": "Lighten", "value": "lighten" },
            { "label": "Color dodge", "value": "color-dodge" },
            { "label": "Color burn", "value": "color-burn" },
            { "label": "Hard light", "value": "hard-light" },
            { "label": "Soft light", "value": "soft-light" },
            { "label": "Difference", "value": "difference" },
            { "label": "Exclusion", "value": "exclusion" },
            { "label": "Hue", "value": "hue" },
            { "label": "Saturation", "value": "saturation" },
            { "label": "Color", "value": "color" },
            { "label": "Luminosity", "value": "luminosity" }
          ]
        }
      ]
    }
  ]
}
