{% if video.lg.url %}
  <video
    {{ video.id }}
    {{ video.dataset }}
    {{ video.autoplay }}
    loop
    muted
    playsinline
  ></video>
{% endif %}

{% if video.modal %}
  {% if video.showModalButton %}
    {% include 'components/modal-video-link.twig' %}
  {% endif %}
  {% embed 'includes/modal.twig' with { modal: video.modal } %}
    {% block modalBodyContent %}
      {% embed 'components/embed-lazyload.twig' %}
        {% block embedLazyloadContent %}
          {% if video.modal.src.html %}
            {{ video.modal.src.html }}
          {% else %}
            <iframe
              data-ui="video"
              data-video="{{ { autoplay: true }|json }}"
              autoplay
              allow="autoplay"
              title="Modal Video"
              src="{{ video.modal.src.url }}"
              width="100%"
              height="100%"
              webkitallowfullscreen
              mozallowfullscreen
              allowfullscreen
            ></iframe>
          {% endif %}
        {% endblock %}
      {% endembed %}
    {% endblock %}
  {% endembed %}
{% endif %}
