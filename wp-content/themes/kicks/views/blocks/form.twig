{% extends 'includes/block.twig' %}

{% block innerBlocksContent %}
  {% if iframeUrl %}
    <iframe
      src="{{ iframeUrl }}"
      id="gform-{{ attributes.formId }}"
      width="100%"
      height="100%"
      style="border: none;"
      webkitallowfullscreen
      mozallowfullscreen
      allowfullscreen
      loading="lazy"
      class="xd-gravityform-iframe"
    ></iframe>
  {% else %}
    {{ content }}
  {% endif %}
{% endblock %}
