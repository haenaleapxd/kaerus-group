{% extends 'page.twig' %}

{% block hero %}
	<div class="hero hero--destination hero--accommodation hero-full {{ templateProps.heroClassName }}">
		<div class="hero-full__overlay"></div>

		{% if post.thumbnail or post.heroImage %}
			{% include 'components/background-image.twig'  with { backgroundImage: post.heroImage } %}
		{% endif %}

		<div class="hero-full__foreground">
			<div class="container">
				<div class="row">
					<div class="col-9 col-lg-8 offset-1">
						<div class="hero-full__foreground-container">
							<div class="hero-full__foreground-body">
								<div class="hero-full__foreground-body-contents xd-py--lg">
									<h1 class="xd-font__display-2">{{ post.title }}</h1>
									{% if post.price %}
										<h4>{{ post.price }}</h4>
									{% endif %}
									{% if post.heroImage.video.modal.src %}
										{% include 'components/modal-video-link.twig' with { video: post.heroImage.video } %}
									{% endif %}
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
